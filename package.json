{
  "name": "cotomia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:local": "HOME=/tmp/expo-home EXPO_NO_TELEMETRY=1 expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:local": "HOME=/tmp/expo-home EXPO_NO_TELEMETRY=1 expo start --web",
    "export:web": "HOME=/tmp/expo-home EXPO_NO_TELEMETRY=1 expo export --platform web --output-dir dist",
    "test": "node --test tests/*.test.ts",
    "validate-content": "node scripts/validate-content.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@types/react": "^19.2.14",
    "expo": "^55.0.6",
    "expo-constants": "^55.0.7",
    "expo-linking": "^55.0.7",
    "expo-router": "^55.0.5",
    "expo-status-bar": "^55.0.4",
    "react": "^19.2.4",
    "react-native": "^0.84.1",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-web": "^0.21.0",
    "typescript": "^5.9.3",
    "zustand": "^5.0.11"
  }
}
